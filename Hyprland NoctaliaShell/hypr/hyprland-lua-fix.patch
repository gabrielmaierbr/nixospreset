diff --git a/Scripts/bash/template-apply.sh b/Scripts/bash/template-apply.sh
index b7fc92dfc..ee92a22b9 100755
--- a/Scripts/bash/template-apply.sh
+++ b/Scripts/bash/template-apply.sh
@@ -334,20 +334,37 @@ niri)
 hyprland)
     echo "🎨 Applying 'noctalia' theme to Hyprland..."
     CONFIG_DIR="$HOME/.config/hypr"
-    CONFIG_FILE="$CONFIG_DIR/hyprland.conf"
-    THEME_FILE="$CONFIG_DIR/noctalia/noctalia-colors.conf"
-
-    INCLUDE_LINE="source = $THEME_FILE"
-
-    # Check if the config file exists.
-    if [ ! -f "$CONFIG_FILE" ]; then
+    LEGACY_CONFIG_FILE="$CONFIG_DIR/hyprland.conf"
+    LUA_CONFIG_FILE="$CONFIG_DIR/hyprland.lua"
+    LEGACY_THEME_FILE="$CONFIG_DIR/noctalia/noctalia-colors.conf"
+    LUA_THEME_FILE="$CONFIG_DIR/noctalia/noctalia-colors.lua"
+
+    LEGACY_INCLUDE_LINE="source = $LEGACY_THEME_FILE"
+    LUA_INCLUDE_LINE="dofile(\"$LUA_THEME_FILE\")"
+
+    # Prefer Lua config on new Hyprland versions, keep legacy fallback.
+    if [ -f "$LUA_CONFIG_FILE" ]; then
+        CONFIG_FILE="$LUA_CONFIG_FILE"
+        INCLUDE_LINE="$LUA_INCLUDE_LINE"
+        INCLUDE_MATCH='dofile\s*\(.*noctalia.*\.lua|require\s*\(.*noctalia'
+    elif [ -f "$LEGACY_CONFIG_FILE" ]; then
+        CONFIG_FILE="$LEGACY_CONFIG_FILE"
+        INCLUDE_LINE="$LEGACY_INCLUDE_LINE"
+        INCLUDE_MATCH='source\s*=\s*.*noctalia.*\.conf'
+    else
+        # No config exists yet, create a Lua config by default.
+        CONFIG_FILE="$LUA_CONFIG_FILE"
+        INCLUDE_LINE="$LUA_INCLUDE_LINE"
+        INCLUDE_MATCH='dofile\s*\(.*noctalia.*\.lua|require\s*\(.*noctalia'
         echo "Config file not found, creating $CONFIG_FILE..."
         mkdir -p "$(dirname "$CONFIG_FILE")"
         echo -e "\n$INCLUDE_LINE\n" >"$CONFIG_FILE"
         echo "Created new config file with noctalia theme."
-    else
-        # Check if noctalia theme source already exists (flexible matching)
-        if grep -qE 'source\s*=\s*.*noctalia.*\.conf' "$CONFIG_FILE"; then
+    fi
+
+    if [ -f "$CONFIG_FILE" ]; then
+        # Check if noctalia include already exists (flexible matching)
+        if grep -qE "$INCLUDE_MATCH" "$CONFIG_FILE"; then
             echo "Theme already included, skipping modification."
         else
             # Only convert symlink when we actually need to write (NixOS read-only symlinks)
diff --git a/Services/Compositor/HyprlandService.qml b/Services/Compositor/HyprlandService.qml
index 19cd80480..8ac935f89 100644
--- a/Services/Compositor/HyprlandService.qml
+++ b/Services/Compositor/HyprlandService.qml
@@ -23,6 +23,7 @@ Item {
   property bool initialized: false
   property var workspaceCache: ({})
   property var windowCache: ({})
+  property string dispatchMode: "unknown" // "unknown", "lua", "legacy"
 
   // Debounce timer for window updates
   Timer {
@@ -524,14 +525,157 @@ Item {
     }
   }
 
+  // Hyprctl dispatch helpers (Lua config compatibility)
+  function runHyprctl(commandArgs, onDone) {
+    const proc = Qt.createQmlObject(`import Quickshell.Io
+Process {
+  id: procObj
+  property string accumulatedOutput: ""
+  stdout: SplitParser {
+    onRead: function (line) {
+      procObj.accumulatedOutput += line;
+    }
+  }
+  stderr: SplitParser {
+    onRead: function (line) {
+      procObj.accumulatedOutput += line;
+    }
+  }
+}`, root);
+    proc.command = ["hyprctl"].concat(commandArgs);
+    Logger.d("HyprlandService", "hyprctl", proc.command.join(" "));
+    proc.exited.connect(function (exitCode) {
+      const output = (proc.accumulatedOutput || "").toLowerCase();
+      const hasError = output.includes("error:") || output.includes("invalid") || output.includes("failed");
+      if (proc.accumulatedOutput) {
+        Logger.d("HyprlandService", "hyprctl output:", proc.accumulatedOutput.trim());
+      }
+      Logger.d("HyprlandService", "hyprctl exit:", exitCode, "errorDetected:", hasError);
+      if (onDone)
+        onDone(exitCode === 0 && !hasError);
+      proc.destroy();
+    });
+    proc.running = true;
+  }
+
+  function escapeLuaString(text) {
+    return String(text).replace(/\\/g, "\\\\").replace(/\"/g, "\\\"");
+  }
+
+  function luaQuote(text) {
+    return "\"" + escapeLuaString(text) + "\"";
+  }
+
+  function luaArg(arg) {
+    if (typeof arg === "number")
+      return String(arg);
+    if (typeof arg === "string" && /^-?\d+$/.test(arg))
+      return arg;
+    return luaQuote(arg);
+  }
+
+  function buildLuaFocusWorkspace(target) {
+    return `hl.dsp.focus({ workspace = ${luaArg(target)} })`;
+  }
+
+  function buildLuaFocusWindow(addr) {
+    return `hl.dsp.focus({ window = ${luaArg(addr)} })`;
+  }
+
+  function buildLuaAlterZOrderTop(addr) {
+    return `hl.dsp.window.alter_zorder({ mode = "top", window = ${luaArg(addr)} })`;
+  }
+
+  function buildLuaKillWindow(addr) {
+    return `hl.dsp.window.kill({ window = ${luaArg(addr)} })`;
+  }
+
+  function buildLuaCloseWindow(addr) {
+    return `hl.dsp.window.close({ window = ${luaArg(addr)} })`;
+  }
+
+  function buildLuaDpms(action) {
+    return `hl.dsp.dpms({ action = ${luaArg(action)} })`;
+  }
+
+  function buildLuaExit() {
+    return "hl.dsp.exit()";
+  }
+
+  function buildLuaExecCmd(cmd) {
+    return `hl.dsp.exec_cmd(${luaQuote(cmd)})`;
+  }
+
+  function dispatchLua(expr, onDone) {
+    runHyprctl(["dispatch", expr], onDone);
+  }
+
+  function dispatchLegacy(args, onDone) {
+    runHyprctl(["dispatch"].concat(args), onDone);
+  }
+
+  function dispatchLuaCandidates(exprs, onDone) {
+    if (!exprs || exprs.length === 0) {
+      if (onDone)
+        onDone(false);
+      return;
+    }
+
+    const next = exprs.slice();
+    const tryNext = function () {
+      if (next.length === 0) {
+        if (onDone)
+          onDone(false);
+        return;
+      }
+      const expr = next.shift();
+      dispatchLua(expr, function (success) {
+        if (success) {
+          if (onDone)
+            onDone(true);
+          return;
+        }
+        tryNext();
+      });
+    };
+
+    tryNext();
+  }
+
+  function dispatchCompat(luaExprs, legacyArgs) {
+    if (dispatchMode === "lua") {
+      dispatchLuaCandidates(luaExprs);
+      return;
+    }
+    if (dispatchMode === "legacy") {
+      dispatchLegacy(legacyArgs);
+      return;
+    }
+
+    dispatchLuaCandidates(luaExprs, function (success) {
+      if (success) {
+        dispatchMode = "lua";
+        return;
+      }
+
+      // Fallback without locking to legacy unless it actually succeeds.
+      dispatchLegacy(legacyArgs, function (legacySuccess) {
+        if (legacySuccess)
+          dispatchMode = "legacy";
+      });
+    });
+  }
+
   // Public functions
   function switchToWorkspace(workspace) {
     try {
-      if (workspace.name) {
-        Hyprland.dispatch(`workspace ${workspace.name}`);
-        return;
-      }
-      Hyprland.dispatch(`workspace ${workspace.idx}`);
+      const name = workspace.name ? String(workspace.name) : "";
+      const hasNumericName = /^-?\d+$/.test(name);
+      const useIdx = workspace.idx !== undefined && workspace.idx !== null && !isNaN(workspace.idx) && (hasNumericName || name === "");
+      const target = useIdx ? workspace.idx : name;
+      dispatchCompat([
+                       buildLuaFocusWorkspace(target)
+                     ], ["workspace", String(target)]);
     } catch (e) {
       Logger.e("HyprlandService", "Failed to switch workspace:", e);
     }
@@ -545,8 +689,13 @@ Item {
       }
 
       const windowId = window.id.toString();
-      Hyprland.dispatch(`focuswindow address:0x${windowId}`);
-      Hyprland.dispatch(`alterzorder top,address:0x${windowId}`); // Bring the focused window to the top (essential for Float Mode)
+      const addr = `address:0x${windowId}`;
+      dispatchCompat([
+                       buildLuaFocusWindow(addr)
+                     ], ["focuswindow", addr]);
+      dispatchCompat([
+                       buildLuaAlterZOrderTop(addr)
+                     ], ["alterzorder", `top,${addr}`]); // Bring the focused window to the top (essential for Float Mode)
     } catch (e) {
       Logger.e("HyprlandService", "Failed to switch window:", e);
     }
@@ -554,7 +703,11 @@ Item {
 
   function closeWindow(window) {
     try {
-      Hyprland.dispatch(`killwindow address:0x${window.id}`);
+      const addr = `address:0x${window.id}`;
+      dispatchCompat([
+                       buildLuaKillWindow(addr),
+                       buildLuaCloseWindow(addr)
+                     ], ["killwindow", addr]);
     } catch (e) {
       Logger.e("HyprlandService", "Failed to close window:", e);
     }
@@ -562,7 +715,9 @@ Item {
 
   function turnOffMonitors() {
     try {
-      Quickshell.execDetached(["hyprctl", "dispatch", "dpms", "off"]);
+      dispatchCompat([
+                       buildLuaDpms("off")
+                     ], ["dpms", "off"]);
     } catch (e) {
       Logger.e("HyprlandService", "Failed to turn off monitors:", e);
     }
@@ -570,7 +725,9 @@ Item {
 
   function turnOnMonitors() {
     try {
-      Quickshell.execDetached(["hyprctl", "dispatch", "dpms", "on"]);
+      dispatchCompat([
+                       buildLuaDpms("on")
+                     ], ["dpms", "on"]);
     } catch (e) {
       Logger.e("HyprlandService", "Failed to turn on monitors:", e);
     }
@@ -578,7 +735,9 @@ Item {
 
   function logout() {
     try {
-      Quickshell.execDetached(["hyprctl", "dispatch", "exit"]);
+      dispatchCompat([
+                       buildLuaExit()
+                     ], ["exit"]);
     } catch (e) {
       Logger.e("HyprlandService", "Failed to logout:", e);
     }
@@ -607,7 +766,10 @@ Item {
 
   function spawn(command) {
     try {
-      Quickshell.execDetached(["hyprctl", "dispatch", "--", "exec"].concat(command));
+      const cmd = command.map(arg => String(arg)).join(" ");
+      dispatchCompat([
+                       buildLuaExecCmd(cmd)
+                     ], ["--", "exec"].concat(command));
     } catch (e) {
       Logger.e("HyprlandService", "Failed to spawn command:", e);
     }
