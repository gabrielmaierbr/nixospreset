From 2cea9a5da04ea0f322f1315c769bbc9240e2f129 Mon Sep 17 00:00:00 2001
From: kyomufs <kyomufsdev@gmail.com>
Date: Mon, 4 May 2026 20:31:38 +0300
Subject: [PATCH] fix: - Hyprland Lua config compatibility for
 HyprlandService.qml - Incompatibility of the current Hyprland template with
 lua syntax

---
 Assets/Templates/hyprland.lua           |  26 ++++
 Scripts/bash/template-apply.sh          |  37 +++--
 Services/Compositor/HyprlandService.qml | 186 ++++++++++++++++++++++--
 Services/Theming/TemplateRegistry.qml   |  12 ++
 4 files changed, 239 insertions(+), 22 deletions(-)
 create mode 100644 Assets/Templates/hyprland.lua

diff --git a/Assets/Templates/hyprland.lua b/Assets/Templates/hyprland.lua
new file mode 100644
index 000000000..50d468908
--- /dev/null
+++ b/Assets/Templates/hyprland.lua
@@ -0,0 +1,26 @@
+hl.config({
+    general = {
+        col = {
+            active_border = "rgb({{colors.primary.default.hex_stripped}})",
+            inactive_border = "rgb({{colors.surface.default.hex_stripped}})",
+        },
+    },
+
+    group = {
+        col = {
+            border_active = "rgb({{colors.secondary.default.hex_stripped}})",
+            border_inactive = "rgb({{colors.surface.default.hex_stripped}})",
+            border_locked_active = "rgb({{colors.error.default.hex_stripped}})",
+            border_locked_inactive = "rgb({{colors.surface.default.hex_stripped}})",
+        },
+
+        groupbar = {
+            col = {
+                active = "rgb({{colors.secondary.default.hex_stripped}})",
+                inactive = "rgb({{colors.surface.default.hex_stripped}})",
+                locked_active = "rgb({{colors.error.default.hex_stripped}})",
+                locked_inactive = "rgb({{colors.surface.default.hex_stripped}})",
